{
  "name": "copilot-channels-extension",
  "version": "0.1.0",
  "description": "Copilot CLI extension that approximates Claude Code style channels and background monitors.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "check": "node --check ./src/copilot-channels-runtime.mjs && node --check ./.github/extensions/copilot-channels-extension/extension.mjs && node --check ./evals/run.mjs && node --check ./examples/heartbeat.mjs",
    "demo:heartbeat": "node ./examples/heartbeat.mjs",
    "evals:list": "node ./evals/run.mjs list",
    "evals:smoke": "node ./evals/run.mjs smoke",
    "evals:run": "node ./evals/run.mjs run --all",
    "evals:validate-modes": "node ./evals/run.mjs validate-modes"
  },
  "keywords": [
    "copilot",
    "copilot-cli",
    "extensions",
    "monitor",
    "channels"
  ],
  "devDependencies": {
    "yaml": "^2.8.3",
    "@github/copilot-sdk": "^0.2.2"
  }
}
